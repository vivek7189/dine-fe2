{
  "name": "dine-frontend",
  "version": "1.9.2",
  "author": "",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "cap:run:ios": "npx cap run ios",
    "tauri": "tauri",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "tauri:export": "node scripts/build-tauri.js",
    "electron:dev": "electron electron/main.js",
    "electron:export": "node scripts/build-electron.js",
    "electron:rebuild": "npx electron-rebuild -f -w better-sqlite3",
    "electron:build": "node scripts/build-electron.js && npx electron-builder --config electron-builder.yml",
    "electron:build:win": "node scripts/build-electron.js && npx electron-builder --config electron-builder.yml --win --x64",
    "electron:build:publish": "node scripts/build-electron.js && npx electron-builder --config electron-builder.yml --publish always",
    "release:gcs": "node scripts/release-gcs.js",
    "release:gcs:upload": "node scripts/release-gcs.js --upload-only"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.2.1",
