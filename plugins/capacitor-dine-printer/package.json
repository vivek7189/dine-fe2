{
  "name": "capacitor-dine-printer",
  "version": "1.0.0",
  "description": "Capacitor plugin for thermal printer support (Bluetooth/USB) in DineOpen POS",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "ios/Plugin/",
