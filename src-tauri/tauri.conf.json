{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DineOpen POS",
  "identifier": "com.dineopen.pos-desktop",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "node scripts/build-tauri.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DineOpen POS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
