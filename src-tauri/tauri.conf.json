{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DineOpen POS",
  "identifier": "com.dineopen.pos-desktop",
  "version": "1.2.0",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "node scripts/build-tauri.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DineOpen POS",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v2Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJEMTUyQTA4RjY0RkM2MkQKUldRdHhrLzJDQ29WTGJIS1p3Y09EcXEydlZUWU1QNmwvOG1ORmFaSDR1WnNTNjNlRU9scGN0MzUK",
      "endpoints": ["https://dine-backend-lake.vercel.app/api/public/desktop-update"]
    }
  }
}
